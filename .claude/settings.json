{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|PowerShell",
        "hooks": [
          { "type": "command", "command": "node \"$CLAUDE_PROJECT_DIR/docs/harness/scripts/hooks/block-push-protected.mjs\"" }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          { "type": "command", "command": "node \"$CLAUDE_PROJECT_DIR/docs/harness/scripts/hooks/protect-frozen.mjs\"" }
        ]
      }
    ]
  }
}
